{
  "expo": {
    "name": "debtor-mobile",
    "slug": "debtor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/debtor-icon.png",
    "scheme": "debtormobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/debtor-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/debtor-fg-icon.png",
        "monochromeImage": "./assets/images/debtor-mono-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/debtor-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#002B36",
          "android": {
            "image": "./assets/images/debtor-splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
